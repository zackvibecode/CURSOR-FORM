NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Local: http://localhost:3000
# Production: https://form.zaqone.com (or your Vercel URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated list of admin emails. These users can access /dashboard/admin
# and approve/reject paid subscription requests.
# Example: ADMIN_EMAILS=me@business.com,partner@business.com
ADMIN_EMAILS=

# Email notifications (Resend) — https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=OneForm <notifications@form.zaqone.com>

# Meta Conversions API (server-side only — DO NOT prefix with NEXT_PUBLIC_)
# Generate token in Meta Events Manager → Settings → Conversions API → Access Tokens
META_CAPI_ACCESS_TOKEN=
# Optional: for testing in Events Manager → Test Events
META_CAPI_TEST_EVENT_CODE=
# Optional: Graph API version (default: v21.0)
META_GRAPH_API_VERSION=v21.0
