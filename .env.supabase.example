# Copy to .env.supabase and fill in values from:
# https://supabase.com/dashboard/project/svnwvkiahtlhahkobtcd/settings/api-keys
#
# Then run: npm run setup:supabase

SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional — for auto-apply migrations without CLI login:
# Create at https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# Optional — database password from Project Settings → Database
SUPABASE_DB_PASSWORD=
